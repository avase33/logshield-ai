# --- Classifier ------------------------------------------------------------
# mock (default, no deps) | onnx
LOGSHIELD_CLASSIFIER=mock
LOGSHIELD_ONNX_MODEL=

# --- Streaming bus ---------------------------------------------------------
# memory (default) | kafka
LOGSHIELD_BUS=memory
KAFKA_BROKERS=localhost:9092
LOGSHIELD_TOPIC=logs.raw
LOGSHIELD_PARTITIONS=8

# --- Storage ---------------------------------------------------------------
# memory | sqlite (default) | clickhouse
LOGSHIELD_STORAGE=sqlite
LOGSHIELD_DB=logshield.db
CLICKHOUSE_URL=http://localhost:8123

# --- Vector store ----------------------------------------------------------
# memory (default) | qdrant
LOGSHIELD_VECTOR=memory
QDRANT_URL=http://localhost:6333

# --- Detection tuning ------------------------------------------------------
LOGSHIELD_CLUSTER_SIM=0.6
LOGSHIELD_MIN_CLUSTER=3
LOGSHIELD_RARE_N=3
LOGSHIELD_SPIKE_Z=3.0
LOGSHIELD_ALERT_SEV=4
LOGSHIELD_WINDOW=60

# --- Alert routing ---------------------------------------------------------
# SLACK_WEBHOOK=https://hooks.slack.com/services/...
# PAGERDUTY_KEY=...
